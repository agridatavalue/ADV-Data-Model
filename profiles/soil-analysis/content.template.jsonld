{
  "@context": {
    "sosa": "http://www.w3.org/ns/sosa/",
    "qudt": "http://qudt.org/schema/qudt/",
    "geo": "http://www.opengis.net/ont/geosparql#",
    "adv": "https://w3id.org/adv/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "unit": "http://qudt.org/vocab/unit/"
  },

  "@id": "https://data.your-domain.org/soil/REPLACE_UNIQUE_ID",
  "@type": "sosa:Observation",

  "adv:externalId": "REPLACE_SAMPLE_OR_LAB_REPORT_ID",

  "sosa:resultTime": { "@value": "REPLACE_ANALYSIS_DATE_UTC", "@type": "xsd:dateTime" },

  "sosa:observedProperty": { "@id": "REPLACE_IRI_EG_http://aims.fao.org/aos/agrovoc/c_acidity" },

  "sosa:hasFeatureOfInterest": {
    "@id": "https://data.your-domain.org/parcel/REPLACE_FIELD_ID",
    "@type": "sosa:FeatureOfInterest"
  },

  "sosa:hasResult": {
    "qudt:numericValue": { "@value": "REPLACE_DECIMAL_VALUE", "@type": "xsd:decimal" },
    "qudt:unit": { "@id": "REPLACE_UNIT_IRI_EG_unit:PH" }
  },

  "adv:samplingDepth": { "@value": "REPLACE_DEPTH_IN_METRES", "@type": "xsd:decimal" },

  "sosa:madeBySensor": {
    "@id": "https://data.your-domain.org/lab/REPLACE_LAB_ID",
    "@type": "sosa:Sensor"
  },

  "adv:issuedAt": { "@value": "REPLACE_OPTIONAL_EMISSION_TIME_UTC", "@type": "xsd:dateTime" }
}
