@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix adv:  <https://w3id.org/adv/core#> .

#################################################################
# SHACL: ADV Observation / Measurement Profile v1.0.0
#
# PURPOSE
# Minimal, implementation-ready constraints for exchanging sensor
# or EO measurements with timestamp, observed property, sensor,
# feature of interest, and a numeric value with a unit.
#
# UPSTREAM ALIGNMENT
# All property paths reference W3C SOSA and QUDT vocabularies.
#################################################################

adv:ObservationShape
  a sh:NodeShape ;
  sh:targetClass sosa:Observation ;

  #################################################################
  # 1) Time of the result
  #################################################################
  sh:property [
    sh:path sosa:resultTime ;
    sh:datatype xsd:dateTime ;
    sh:minCount 1 ;
    sh:message "Observation must have sosa:resultTime (xsd:dateTime, e.g., 2025-09-21T10:35:00Z)." ;
  ] ;

  #################################################################
  # 2) Observed property
  #################################################################
  sh:property [
    sh:path sosa:observedProperty ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "Observation must have sosa:observedProperty as an IRI (e.g., a phenomenon/property term)." ;
  ] ;

  #################################################################
  # 3) Sensor that produced it
  #################################################################
  sh:property [
    sh:path sosa:madeBySensor ;
    sh:minCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:message "Observation must have sosa:madeBySensor (IRI or blank node representing the sensor)." ;
  ] ;

  #################################################################
  # 4) Feature of Interest
  #################################################################
  sh:property [
    sh:path sosa:hasFeatureOfInterest ;
    sh:minCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:message "Observation must have sosa:hasFeatureOfInterest (IRI or blank node representing the observed target)." ;
  ] ;

  #################################################################
  # 5) Result (value + unit via QUDT)
  #################################################################
  sh:property [
    sh:path sosa:hasResult ;
    sh:minCount 1 ;
    sh:node [
      a sh:NodeShape ;
      sh:property [
        sh:path qudt:numericValue ;
        sh:minCount 1 ;
        sh:datatype xsd:decimal ;
        sh:message "Result must include qudt:numericValue (xsd:decimal)." ;
      ] ;
      sh:property [
        sh:path qudt:unit ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Result must include qudt:unit (IRI, e.g., unit:DegreeCelsius)." ;
      ] ;
    ] ;
  ] ;

  #################################################################
  # 6) Optional cross-cutting fields
  #################################################################
  sh:property [
    sh:path adv:externalId ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:severity sh:Info ;
    sh:message "Optional adv:externalId (string) can carry the producer's system ID." ;
  ] ;

  sh:property [
    sh:path adv:issuedAt ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:severity sh:Info ;
    sh:message "Optional adv:issuedAt (xsd:dateTime) indicates when this content instance was emitted." ;
  ] .
