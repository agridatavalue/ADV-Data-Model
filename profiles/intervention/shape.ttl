@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix sosa:   <http://www.w3.org/ns/sosa/> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix foodie: <http://foodie-cloud.com/model/foodie#> .
@prefix adv:    <https://w3id.org/adv/core#> .

#################################################################
# SHACL: ADV Intervention Profile v1.0.0
#
# PURPOSE
# Defines minimal constraints for describing field operations or
# interventions, including type, timing, location (parcel),
# and optionally inputs or outputs.
#
# UPSTREAM ALIGNMENT
# Target class: foodie:Intervention (FOODIE/DEMETER)
# Temporal:     prov:startedAtTime / prov:endedAtTime (W3C PROV)
# Location:     sosa:hasFeatureOfInterest (W3C SOSA)
#################################################################

adv:InterventionShape
  a sh:NodeShape ;
  sh:targetClass foodie:Intervention ;

  #################################################################
  # 1) External identifier
  #################################################################
  sh:property [
    sh:path adv:externalId ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "Each intervention must have adv:externalId (operation or task ID)." ;
  ] ;

  #################################################################
  # 2) Type of intervention
  #################################################################
  sh:property [
    sh:path dct:type ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "Intervention must have dct:type (IRI describing the operation, e.g., spraying, fertilisation)." ;
  ] ;

  #################################################################
  # 3) Start time
  #################################################################
  sh:property [
    sh:path prov:startedAtTime ;
    sh:minCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:message "Intervention must have prov:startedAtTime (xsd:dateTime)." ;
  ] ;

  #################################################################
  # 4) End time
  #################################################################
  sh:property [
    sh:path prov:endedAtTime ;
    sh:minCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:message "Intervention must have prov:endedAtTime (xsd:dateTime)." ;
  ] ;

  #################################################################
  # 5) Target parcel or feature
  #################################################################
  sh:property [
    sh:path sosa:hasFeatureOfInterest ;
    sh:minCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:message "Intervention must specify sosa:hasFeatureOfInterest (the parcel or field where it occurred)." ;
  ] ;

  #################################################################
  # 6) Optional: input (e.g., fertilizer or pesticide)
  #################################################################
  sh:property [
    sh:path prov:used ;
    sh:maxCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:severity sh:Info ;
    sh:message "Optional: prov:used (IRI or blank node for material/product used)." ;
  ] ;

  #################################################################
  # 7) Optional: output (e.g., yield or biomass)
  #################################################################
  sh:property [
    sh:path prov:generated ;
    sh:maxCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:severity sh:Info ;
    sh:message "Optional: prov:generated (IRI or blank node for resulting product or measure)." ;
  ] ;

  #################################################################
  # 8) Optional issue timestamp
  #################################################################
  sh:property [
    sh:path adv:issuedAt ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:severity sh:Info ;
    sh:message "Optional: adv:issuedAt (xsd:dateTime) indicates record creation or update time." ;
  ] .
