{
  "@context": {
    "odrl": "http://www.w3.org/ns/odrl/2/",
    "dct": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },

  "@type": "odrl:Policy",
  "dct:title": "Time-Limited Access",
  "dct:description": "Data access expires after a defined date. Adjust the rightOperand to your agreed end date.",

  "odrl:permission": {
    "@type": "odrl:Permission",
    "odrl:action": "http://www.w3.org/ns/odrl/2/use",
    "odrl:constraint": {
      "odrl:leftOperand": "http://www.w3.org/ns/odrl/2/dateTime",
      "odrl:operator": "http://www.w3.org/ns/odrl/2/lteq",
      "odrl:rightOperand": { "@value": "2026-12-31T23:59:59Z", "@type": "xsd:dateTime" }
    }
  }
}
