@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix sosa:   <http://www.w3.org/ns/sosa/> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix foodie: <http://foodie-cloud.com/model/foodie#> .
@prefix adv:    <https://w3id.org/adv/core#> .

#################################################################
# SHACL: ADV Alert Profile v1.0.0
#
# PURPOSE
# Defines minimal constraints for exchanging alerts, advisories,
# or notifications such as pest, disease, or weather warnings.
#
# UPSTREAM ALIGNMENT
# Target class: foodie:Alert (FOODIE/DEMETER)
# Temporal:     prov:startedAtTime / prov:endedAtTime (W3C PROV)
# Location:     sosa:hasFeatureOfInterest (W3C SOSA)
#################################################################

adv:AlertShape
  a sh:NodeShape ;
  sh:targetClass foodie:Alert ;

  #################################################################
  # 1) External identifier
  #################################################################
  sh:property [
    sh:path adv:externalId ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "Alert must have adv:externalId (unique alert ID)." ;
  ] ;

  #################################################################
  # 2) Alert type (e.g., pest, disease, weather)
  #################################################################
  sh:property [
    sh:path dct:type ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "Alert must have dct:type (IRI describing the alert category)." ;
  ] ;

  #################################################################
  # 3) Severity level
  #################################################################
  sh:property [
    sh:path adv:severity ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "Alert must have adv:severity (IRI referencing a severity level term)." ;
  ] ;

  #################################################################
  # 4) Message or description
  #################################################################
  sh:property [
    sh:path dct:description ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "Alert must have dct:description (human-readable description)." ;
  ] ;

  #################################################################
  # 5) Target feature (field, crop, animal, region)
  #################################################################
  sh:property [
    sh:path sosa:hasFeatureOfInterest ;
    sh:minCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:message "Alert must specify sosa:hasFeatureOfInterest (affected entity or location)." ;
  ] ;

  #################################################################
  # 6) Optional start and end time
  #################################################################
  sh:property [
    sh:path prov:startedAtTime ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:severity sh:Info ;
    sh:message "Optional: prov:startedAtTime (when the alert became active)." ;
  ] ;
  sh:property [
    sh:path prov:endedAtTime ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:severity sh:Info ;
    sh:message "Optional: prov:endedAtTime (when the alert expired or was resolved)." ;
  ] ;

  #################################################################
  # 7) Optional issue timestamp
  #################################################################
  sh:property [
    sh:path adv:issuedAt ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:severity sh:Info ;
    sh:message "Optional: adv:issuedAt (xsd:dateTime) indicates alert creation or update time." ;
  ] .
