{
  "@context": {
    "odrl": "http://www.w3.org/ns/odrl/2/",
    "dct": "http://purl.org/dc/terms/"
  },

  "@type": "odrl:Policy",
  "dct:title": "Consortium Only",
  "dct:description": "Data may only be used by members of the specified project consortium. Redistribution outside the consortium is prohibited.",

  "odrl:permission": {
    "@type": "odrl:Permission",
    "odrl:action": "http://www.w3.org/ns/odrl/2/use",
    "odrl:constraint": {
      "odrl:leftOperand": "http://www.w3.org/ns/odrl/2/recipient",
      "odrl:operator": "http://www.w3.org/ns/odrl/2/isPartOf",
      "odrl:rightOperand": { "@id": "REPLACE_WITH_CONSORTIUM_IRI" }
    }
  },

  "odrl:prohibition": {
    "@type": "odrl:Prohibition",
    "odrl:action": "http://www.w3.org/ns/odrl/2/distribute"
  }
}
