@prefix sh:         <http://www.w3.org/ns/shacl#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix saref4agri: <https://saref.etsi.org/saref4agri/> .
@prefix adv:        <https://w3id.org/adv/core#> .

#################################################################
# SHACL: ADV Animal Profile v1.0.0
#
# PURPOSE
# Defines minimal constraints for describing an animal or group of
# animals with identifiers, species, birth date, and optional
# production or health indicators.
#
# UPSTREAM ALIGNMENT
# Target class: saref4agri:Animal (ETSI SAREF4AGRI)
# Animal-specific properties are minted by ADV because no single
# upstream vocabulary (SAREF4AGRI, Schema.org, SmartDataModels)
# provides a stable, consistent set for all five fields.
#################################################################

adv:AnimalShape
  a sh:NodeShape ;
  sh:targetClass saref4agri:Animal ;

  #################################################################
  # 1) External identifier
  #################################################################
  sh:property [
    sh:path adv:externalId ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "Animal must have adv:externalId (official or farm ID)." ;
  ] ;

  #################################################################
  # 2) Species or type
  #################################################################
  sh:property [
    sh:path adv:species ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "Animal must have adv:species (IRI reference to a species term, e.g., from NCBI Taxonomy or Wikidata)." ;
  ] ;

  #################################################################
  # 3) Date of birth
  #################################################################
  sh:property [
    sh:path adv:birthDate ;
    sh:minCount 1 ;
    sh:datatype xsd:date ;
    sh:message "Animal must have adv:birthDate (xsd:date)." ;
  ] ;

  #################################################################
  # 4) Optional sex
  #################################################################
  sh:property [
    sh:path adv:sex ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:severity sh:Info ;
    sh:message "Optional: adv:sex (IRI for male/female/other)." ;
  ] ;

  #################################################################
  # 5) Optional production type
  #################################################################
  sh:property [
    sh:path adv:productionType ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:severity sh:Info ;
    sh:message "Optional: adv:productionType (IRI for dairy, meat, egg, etc.)." ;
  ] ;

  #################################################################
  # 6) Optional parent link
  #################################################################
  sh:property [
    sh:path adv:hasParent ;
    sh:maxCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:severity sh:Info ;
    sh:message "Optional: adv:hasParent (link to parent animal record)." ;
  ] ;

  #################################################################
  # 7) Optional issue timestamp
  #################################################################
  sh:property [
    sh:path adv:issuedAt ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:severity sh:Info ;
    sh:message "Optional: adv:issuedAt (xsd:dateTime) indicates record update or registration time." ;
  ] .
