{
  "@context": {
    "sosa": "http://www.w3.org/ns/sosa/",
    "qudt": "http://qudt.org/schema/qudt/",
    "geo": "http://www.opengis.net/ont/geosparql#",
    "adv": "https://w3id.org/adv/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "unit": "http://qudt.org/vocab/unit/"
  },

  "@id": "https://data.your-domain.org/weather/REPLACE_UNIQUE_ID",
  "@type": "sosa:Observation",

  "sosa:resultTime": { "@value": "REPLACE_TIMESTAMP_UTC", "@type": "xsd:dateTime" },

  "sosa:observedProperty": { "@id": "REPLACE_IRI_EG_http://qudt.org/vocab/quantitykind/Temperature" },

  "sosa:madeBySensor": {
    "@id": "https://data.your-domain.org/station/REPLACE_STATION_ID",
    "@type": "sosa:Sensor"
  },

  "sosa:hasFeatureOfInterest": {
    "@id": "https://data.your-domain.org/location/REPLACE_LOCATION_ID",
    "@type": "sosa:FeatureOfInterest"
  },

  "sosa:hasResult": {
    "qudt:numericValue": { "@value": "REPLACE_DECIMAL_VALUE", "@type": "xsd:decimal" },
    "qudt:unit": { "@id": "REPLACE_UNIT_IRI_EG_unit:DegreeCelsius" }
  },

  "adv:externalId": "REPLACE_OPTIONAL_STATION_OR_RECORD_ID",
  "adv:issuedAt": { "@value": "REPLACE_OPTIONAL_EMISSION_TIME_UTC", "@type": "xsd:dateTime" }
}
