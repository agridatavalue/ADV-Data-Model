{
  "@context": {
    "odrl": "http://www.w3.org/ns/odrl/2/",
    "dct": "http://purl.org/dc/terms/"
  },

  "@type": "odrl:Policy",
  "dct:title": "Research Only",
  "dct:description": "Data may be used for research purposes only. Commercial use and redistribution are prohibited.",

  "odrl:permission": {
    "@type": "odrl:Permission",
    "odrl:action": "http://www.w3.org/ns/odrl/2/use",
    "odrl:constraint": {
      "odrl:leftOperand": "http://www.w3.org/ns/odrl/2/purpose",
      "odrl:operator": "http://www.w3.org/ns/odrl/2/eq",
      "odrl:rightOperand": "https://w3id.org/dpv#ResearchAndDevelopment"
    }
  },

  "odrl:prohibition": {
    "@type": "odrl:Prohibition",
    "odrl:action": "http://www.w3.org/ns/odrl/2/distribute"
  }
}
