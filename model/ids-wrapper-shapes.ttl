@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix ids:  <https://w3id.org/idsa/core/> .
@prefix adv:  <https://w3id.org/adv/core#> .

#################################################################
# SHACL: IDS wrapper conformance for ADV exchanges
#
# PURPOSE
# Validate that IDS-layer offers (resources) are discoverable and
# consistently reference an ADV operational profile.
#
# SCOPE
# Minimal, practical checks only (title, description, identifier,
# profile id + version). Optional checks for license and issued date.
#
# NOTE
# Namespaces use W3ID identifiers which may not yet resolve in a browser.
#################################################################

ids:OfferShape
  a sh:NodeShape ;
  sh:targetClass ids:Resource ;

  # -- Title (human-readable)
  sh:property [
    sh:path dct:title ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "IDS Resource must have dct:title (string)." ;
  ] ;

  # -- Description (human-readable)
  sh:property [
    sh:path dct:description ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "IDS Resource must have dct:description (string)." ;
  ] ;

  # -- Stable identifier for the offer
  sh:property [
    sh:path dct:identifier ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:pattern "^[A-Za-z0-9._:/\\-]+$" ;
    sh:message "IDS Resource must have dct:identifier (string). Use letters, digits, dots, dashes, slashes or colons." ;
  ] ;

  # -- ADV profile identifier (must be one of the registered profile IDs)
  sh:property [
    sh:path adv:profileId ;
    sh:minCount 1 ;
    sh:in ("adv.observation" "adv.parcel-crop" "adv.intervention" "adv.animal" "adv.alert") ;
    sh:message "Offer must declare adv:profileId set to one of: adv.observation, adv.parcel-crop, adv.intervention, adv.animal, adv.alert." ;
  ] ;

  # -- ADV profile version (semver)
  sh:property [
    sh:path adv:profileVersion ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:pattern "^[0-9]+\\.[0-9]+\\.[0-9]+$" ;
    sh:message "Offer must declare adv:profileVersion in MAJOR.MINOR.PATCH format, e.g., 1.0.0." ;
  ] ;

  # -- Optional: license IRI (good practice for discovery)
  sh:property [
    sh:path dct:license ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:severity sh:Warning ;
    sh:message "Recommended: provide dct:license as an IRI (e.g., a Creative Commons URL)." ;
  ] ;

  # -- Optional: issued date
  sh:property [
    sh:path dct:issued ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:severity sh:Warning ;
    sh:message "Recommended: provide dct:issued (xsd:dateTime) for the offer metadata." ;
  ] .
