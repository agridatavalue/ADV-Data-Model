@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix adv:  <https://w3id.org/adv/core#> .

#################################################################
# SHACL: Minimal ODRL policy validation for ADV offers
#
# PURPOSE
# Ensures that an ODRL policy attached to an ADV dataset offer
# contains at least one permission or prohibition rule, and that
# each rule specifies an action.
#
# This is intentionally lightweight: it validates structure, not
# the business logic of the policy.
#################################################################

adv:PolicyShape
  a sh:NodeShape ;
  sh:targetClass odrl:Policy ;

  # -- At least one permission OR prohibition must exist
  sh:or (
    [ sh:property [ sh:path odrl:permission ; sh:minCount 1 ] ]
    [ sh:property [ sh:path odrl:prohibition ; sh:minCount 1 ] ]
  ) ;

  # -- Optional title for the policy
  sh:property [
    sh:path dct:title ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:severity sh:Info ;
    sh:message "Optional: dct:title for human-readable policy name." ;
  ] .


#################################################################
# Permission sub-shape
#################################################################

adv:PermissionShape
  a sh:NodeShape ;
  sh:targetClass odrl:Permission ;

  sh:property [
    sh:path odrl:action ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "Permission must specify odrl:action (IRI, e.g., odrl:use, odrl:distribute)." ;
  ] ;

  sh:property [
    sh:path odrl:constraint ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:severity sh:Info ;
    sh:message "Optional: odrl:constraint to limit the scope of the permission." ;
  ] .


#################################################################
# Prohibition sub-shape
#################################################################

adv:ProhibitionShape
  a sh:NodeShape ;
  sh:targetClass odrl:Prohibition ;

  sh:property [
    sh:path odrl:action ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "Prohibition must specify odrl:action (IRI, e.g., odrl:distribute)." ;
  ] .
